#!/bin/sh
# Eddic tier-2 backup: refresh the blob inventory (.eddic/assets.json) and
# stage it on every commit. Thin POSIX-sh shim — all logic is in the Python
# worker. Best-effort: never blocks a commit.
root=$(git rev-parse --show-toplevel) || exit 0
worker="$root/.eddic/lib/backup/assets.py"
[ -f "$worker" ] || exit 0
py=$(command -v python3 || command -v python) || exit 0
"$py" "$worker" --root "$root" >/dev/null 2>&1 || exit 0
git add "$root/.eddic/assets.json" 2>/dev/null || true
exit 0
